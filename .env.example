# ScholarNavigator backend local environment template.
# Copy this file to .env and fill values locally. Do not commit .env.

# OpenAI-compatible LLM provider. Leave disabled for no-LLM local runs.
SCHOLAR_AGENT_LLM_PROVIDER=disabled
SCHOLAR_AGENT_LLM_BASE_URL=https://api.openai.com/v1
SCHOLAR_AGENT_LLM_API_KEY=
SCHOLAR_AGENT_LLM_MODEL=gpt-4.1-mini
SCHOLAR_AGENT_LLM_TIMEOUT_SECONDS=30
SCHOLAR_AGENT_LLM_QUERY_UNDERSTANDING_TIMEOUT_SECONDS=20
SCHOLAR_AGENT_LLM_MAX_TOKENS=1024
SCHOLAR_AGENT_LLM_NVIDIA_THINKING=false

# Optional LLM stages. They require a configured provider and API key.
SCHOLAR_AGENT_ENABLE_LLM_QUERY_UNDERSTANDING=0
SCHOLAR_AGENT_ENABLE_LLM_JUDGEMENT=0
SCHOLAR_AGENT_LLM_JUDGEMENT_BATCH_SIZE=8
SCHOLAR_AGENT_LLM_JUDGEMENT_MAX_PAPERS=8
SCHOLAR_AGENT_LLM_JUDGEMENT_TIMEOUT_SECONDS=25

# Academic connector options.
OPENALEX_MAILTO=

# Real Search runtime options.
SCHOLAR_AGENT_RETRIEVAL_CACHE=1
REAL_SEARCH_MAX_WORKERS=1
REAL_SEARCH_BACKGROUND_WORKERS=2
REAL_SEARCH_RUN_TTL_SECONDS=3600
REAL_SEARCH_MAX_STORED_RUNS=200

# Add custom frontend dev origins if needed. Defaults already include 3000/3001/5173.
SCHOLAR_AGENT_CORS_ORIGINS=
