{
  "experiment": "lexical_normalization_v1",
  "implementation_base_commit": "005794ced76151934c3e3ca0b695717fce03fcf0",
  "policy": {
    "config_field": "lexical_normalization_policy",
    "default": "off",
    "experimental_value": "lexical_normalization_v1",
    "applies_only_to_facets": [
      "topic",
      "must_have",
      "method",
      "domain"
    ],
    "excluded_facets": [
      "dataset",
      "exclude",
      "paper_type",
      "venue",
      "time",
      "task"
    ]
  },
  "normalization": {
    "version": "lexical-normalization-v1",
    "ordered_steps": [
      "unicode_nfkc",
      "casefold",
      "strip_english_possessive_suffix",
      "collapse_dotted_letter_abbreviations",
      "split_unicode_punctuation_and_hyphens",
      "apply_conservative_english_singular_plural_variants"
    ],
    "matching": "contiguous_whole_token_sequence",
    "plural_rules": [
      "consonant+y plural ies -> y when token length > 4",
      "ch/sh/x/z/ss plural es -> remove es when token length > 4",
      "terminal s -> remove s when token length > 4 except ss/us/is"
    ],
    "short_token_rule": "tokens of length <= 3 are preserved exactly and never singularized",
    "score_semantics": "existing field weights and facet caps; each diagnostic impact is the marginal capped score increase in original term order"
  },
  "non_goals": [
    "no synonyms",
    "no semantic expansion",
    "no fuzzy edit distance",
    "no stemming beyond the listed singular/plural rules",
    "no acronym expansion beyond punctuation-equivalent dotted letters",
    "no gold, title, case ID, crosswalk, or dataset-specific rules"
  ],
  "frozen_inputs": [
